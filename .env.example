SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
# Service-role key — bypasses RLS, used by server-only admin client
# (client.server.ts) for screening interviews and admin operations.
# Get it from: Supabase Dashboard → Project Settings → API → service_role.
# SECRET: server-side only, never expose to the client / never prefix VITE_.
SUPABASE_SERVICE_ROLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# AI provider (vendor-neutral, OpenAI-compatible). Required for
# "Draft rubric with AI", screening interviews, and evidence extraction.
# Set these to any OpenAI-compatible provider you control. Examples:
#
#   OpenAI:     AI_BASE_URL="https://api.openai.com/v1"
#               AI_MODEL="gpt-4o-mini"
#   OpenRouter: AI_BASE_URL="https://openrouter.ai/api/v1"
#               AI_MODEL="anthropic/claude-3.5-sonnet"   # or any model OpenRouter serves
#   Groq:       AI_BASE_URL="https://api.groq.com/openai/v1"
#               AI_MODEL="llama-3.3-70b-versatile"
#   Google:     AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
#               AI_MODEL="gemini-2.0-flash"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""
# Optional model tiering (spec §7): a cheap/fast model for screening turn-taking
# and a stronger model for evidence extraction. Both fall back to AI_MODEL.
AI_MODEL_FAST=""
AI_MODEL_STRONG=""

# Async evidence-extraction queue (scalability #2). When set (any value) AND a
# scheduler invokes runQueuedJobs, screen completion enqueues an extract_evidence
# job instead of running inline. Leave empty to keep the safe inline default.
USE_EVIDENCE_QUEUE=""
# Shared secret the scheduler passes to runQueuedJobs (the queue worker).
WORKER_SECRET=""

# Shared secret for the voice-screening transcript webhook (M3). The voice
# provider signs each POST with HMAC-SHA256 over
# `${applicationId}:${JSON.stringify(transcript)}`. Leave empty to disable
# voice intake. Use any long random string.
VOICE_WEBHOOK_SECRET=""
